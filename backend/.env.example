# Backend environment variables for local development
# Copy this to .env and fill in your values
# NEVER commit .env to git

PORT=8080
DB_URL=jdbc:mysql://your-aiven-host:port/defaultdb?sslMode=REQUIRED&serverTimezone=UTC
DB_USERNAME=your_aiven_username
DB_PASSWORD=your_aiven_password
JWT_SECRET=your-strong-jwt-secret-at-least-32-chars-long
